# 复制为 .env 后填写真实配置：
# cp .env.example .env

# 截图频率：300 = 每 5 分钟一次
INTERVAL_SECONDS=300

# 截图保存位置和保留数量
OUTPUT_DIR=screenshots
SCREENSHOT_PREFIX=uu_screenshot
RETENTION_COUNT=100
LOG_FILE=uu_screenshot.log

# macOS 可选：截图前先把 UU 远程拉到前台。
# 应用名要和 macOS 里看到的应用名一致；不确定就先留空。
MAC_ACTIVATE_APP_NAME=
SCREENSHOT_DELAY_SECONDS=0.5

# macOS 可选：只截某个窗口或显示器。通常先留空，默认截全屏。
MAC_WINDOW_ID=
MAC_DISPLAY_ID=
MAC_OMIT_WINDOW_SHADOW=true

# 高级可选：用你自己的截图命令，{output} 会被替换成目标文件路径。
# SCREENSHOT_COMMAND=screencapture -x -t png "{output}"

# 邮件：QQ 邮箱请使用 SMTP 授权码，不要填 QQ 登录密码。
EMAIL_ENABLED=true
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_SECURITY=ssl
SMTP_USERNAME=你的QQ邮箱@qq.com
MAIL_FROM=你的QQ邮箱@qq.com
MAIL_TO=接收邮箱@qq.com
MAIL_SUBJECT=UU远程自动截图
MAIL_SUBJECT_WITH_TIME=true
EMAIL_ATTACH_SCREENSHOT=true

# 更安全：公共 Windows 机器上建议不要在 .env 写 SMTP_PASSWORD。
# 先安装 keyring：python -m pip install keyring
# 再运行：python uu_screenshot_monitor.py --env .env --store-smtp-password
# 然后保持下面这两项，SMTP_PASSWORD 留空或不写。
SMTP_PASSWORD=
SMTP_PASSWORD_KEYRING_SERVICE=uu_screenshot_smtp
SMTP_PASSWORD_KEYRING_USERNAME=你的QQ邮箱@qq.com

# Server酱：只发提醒文字。截图本体建议走邮件附件。
SERVERCHAN_SENDKEY=

# Bark：只发提醒文字。截图本体建议走邮件附件。
BARK_KEY=
BARK_SERVER=https://api.day.app
BARK_OPEN_URL=

# 通用 Webhook：适合接企业微信机器人、飞书机器人、自己写的 QQ 机器人等。
# 默认 POST JSON；如果服务要求表单，改成 PUSH_WEBHOOK_FORMAT=form。
PUSH_WEBHOOK_URL=
PUSH_WEBHOOK_METHOD=POST
PUSH_WEBHOOK_FORMAT=json
PUSH_TIMEOUT_SECONDS=20
PUSH_TITLE=UU远程截图已生成

# Twilio 短信：只发文字提醒，不发图片。
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
TWILIO_TO=
